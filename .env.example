# ============================================
# Universal Trading Bot - Environment Config
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# --- BINANCE API KEYS ---
# Get your keys from: https://www.binance.com/en/my/settings/api-management
# For testnet: https://testnet.binance.vision/
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_SECRET_KEY=YOUR_BINANCE_SECRET_KEY_HERE

# --- TRADING CONFIGURATION ---
# Options: testnet | live
TRADING_MODE=testnet

# Initial capital in USDT
INITIAL_CAPITAL=1000

# Risk per trade (percentage, e.g. 2 = 2%)
MAX_RISK_PER_TRADE=2

# Trading pairs (comma separated)
TRADING_PAIRS=BTC/USDT,ETH/USDT,BNB/USDT

# --- NEWS API KEY ---
# Get free key from: https://cryptopanic.com/developer/
# Or use NewsAPI: https://newsapi.org/
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# --- SERVER CONFIG ---
PORT=3020

# --- LOGGING ---
# Options: error | warn | info | debug
LOG_LEVEL=info

# --- PLATFORM ---
# Options: crypto | forex | stocks
PLATFORM=crypto

# --- AUTO TRADING ---
# Set to true to enable automatic trading
AUTO_TRADE=false

# --- NOTIFICATIONS ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

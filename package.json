{
  "name": "universal-trading-bot",
  "version": "1.0.0",
  "description": "Platform-aware intelligent trading bot for Crypto, Forex, and Stocks",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:crypto": "PLATFORM=crypto node src/index.js",
    "start:forex": "PLATFORM=forex node src/index.js",
    "start:stocks": "PLATFORM=stocks node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:crypto": "PLATFORM=crypto jest",
    "test:forex": "PLATFORM=forex jest",
    "test:stocks": "PLATFORM=stocks jest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "docker:build": "docker build -t universal-trading-bot .",
    "docker:run": "docker run -d --name universal-trading-bot universal-trading-bot",
    "docker:stop": "docker stop universal-trading-bot && docker rm universal-trading-bot",
    "deploy:testnet": "TESTNET=true node src/index.js",
    "backtest:crypto": "PLATFORM=crypto node scripts/backtest.js",
    "analyze:market": "node scripts/market-analysis.js"
  },
  "keywords": [
    "trading",
    "bot",
    "crypto",
    "forex",
    "stocks",
    "universal",
    "intelligent",
    "ai",
    "trading-bot",
    "binance",
    "oanda",
    "zerodha"
  ],
  "author": "Universal Trading Bot Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.0",
    "axios": "^1.3.0",
    "ws": "^8.5.0",
    "crypto-js": "^4.1.1",
    "express": "^4.18.0",
    "socket.io": "^4.5.0",
    "natural": "^6.0.0",
    "node-cron": "^3.0.0",
    "technicalindicators": "^3.1.0",
    "ccxt": "^3.0.0",
    "moment": "^2.29.4",
    "winston": "^3.8.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^2.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "supertest": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/universal-trading-bot.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/universal-trading-bot/issues"
  },
  "homepage": "https://github.com/yourusername/universal-trading-bot#readme"
}